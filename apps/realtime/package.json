    "@nestjs/platform-express": "^11.0.5",
    "@nestjs/platform-socket.io": "^11.0.5",
    "@nestjs/websockets": "^11.0.5",
    "@sentry/node": "^8.45.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.2",
    "@nestjs/schematics": "^11.0.0",
    "dotenv-cli": "^8.0.0",
    "@types/jsonwebtoken": "^9.0.7",
