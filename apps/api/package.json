    "@mvs/shared": "workspace:*",
    "@nestjs/common": "^11.0.5",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.5",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.5",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.4.0",
    "@sentry/node": "^8.45.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
