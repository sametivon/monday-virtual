# ──────────────────────────────────────────────────────────────────────────
# Monday Virtual Spaces — environment template
# Copy to `.env` and fill in. NEVER commit real secrets. (.env is gitignored)
# ──────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Core service URLs (local dev) ──────────────────────────────────────────
API_PORT=4000
REALTIME_PORT=4001
WEB_PORT=3000
WEB_PUBLIC_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000
REALTIME_PUBLIC_URL=http://localhost:4001

# ── Database (Postgres) ────────────────────────────────────────────────────
# Local docker-compose default (host port 5433 to avoid clashing with other
# local Postgres instances); in prod use Neon/Supabase/RDS connection string.
DATABASE_URL=postgresql://mvs:mvs@localhost:5433/mvs?schema=public
# Direct (unpooled) URL for prisma migrations. Locally identical to DATABASE_URL.
# In prod (Neon) set DATABASE_URL to the POOLED url and this to the DIRECT url.
DIRECT_DATABASE_URL=postgresql://mvs:mvs@localhost:5433/mvs?schema=public

# ── Redis (Socket.IO adapter, presence, cache, rate-limit) ─────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-32-byte-hex
JWT_REFRESH_SECRET=replace-with-another-32-byte-hex
JWT_ACCESS_TTL=900            # seconds (15m)
JWT_REFRESH_TTL=2592000       # seconds (30d)
# AES-256-GCM key (32-byte hex) for encrypting Monday tokens at rest
ENCRYPTION_KEY=replace-with-32-byte-hex

# ── monday.com app (Developer Center) ──────────────────────────────────────
MONDAY_CLIENT_ID=
# Client secret signs the iframe sessionToken (required for seamless auth).
MONDAY_CLIENT_SECRET=
# Signing secret verifies board webhooks; also fallback for dev tokens.
MONDAY_SIGNING_SECRET=
MONDAY_OAUTH_REDIRECT_URI=http://localhost:4000/auth/monday/callback
MONDAY_SCOPES=me:read boards:read users:read account:read

# ── LiveKit Cloud (media plane) ────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Object storage (S3-compatible: Cloudflare R2 / AWS S3 / MinIO) ─────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=mvs-assets
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_PUBLIC_BASE_URL=http://localhost:9000/mvs-assets

# ── AI (OpenAI-compatible abstraction; can point at OpenAI, Azure, local) ──
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── Observability ──────────────────────────────────────────────────────────
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=mvs

# ── Public (exposed to the Next.js client; must be NEXT_PUBLIC_*) ──────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_REALTIME_URL=http://localhost:4001
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
NEXT_PUBLIC_SENTRY_DSN=
