{
  "name": "@mvs/db",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "push": "dotenv -e ../../.env -- prisma db push",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "build": "prisma generate && tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "echo \"(db) no lint\"",
    "test": "echo \"(db) no tests\"",
    "clean": "rimraf dist .turbo node_modules/.prisma"
  },
  "dependencies": {
    "@mvs/config": "workspace:*",
    "@mvs/shared": "workspace:*",
    "@prisma/client": "^6.2.1"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.2.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
