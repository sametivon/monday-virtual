# ──────────────────────────────────────────────────────────────────────────
# Monday Virtual Spaces — PRODUCTION environment reference
#
# This is NOT loaded by a process. In prod each variable is set in the dashboard
# of the host that runs that service (Render / Vercel / GitHub Actions). This
# file documents WHICH vars go WHERE and where each value comes from.
# Generate fresh secrets — NEVER reuse the local dev values.
# ──────────────────────────────────────────────────────────────────────────

# ===========================================================================
# RENDER · service "mvs-api"  (NestJS REST API)   — set in Render dashboard
# ===========================================================================
NODE_ENV=production
# Render injects $PORT automatically — do NOT set API_PORT.
WEB_PUBLIC_URL=https://mondayvirtual.eu            # the Vercel app origin (CORS allow-list)

# Neon: DATABASE_URL = POOLED connection string (has "-pooler" in the host).
DATABASE_URL=postgresql://USER:PASS@ep-xxx-pooler.eu-central-1.aws.neon.tech/mvs?sslmode=require

# Auth secrets — generate each with: openssl rand -hex 32
JWT_SECRET=                                         # 32-byte hex — MUST equal mvs-realtime's
JWT_REFRESH_SECRET=                                 # 32-byte hex
ENCRYPTION_KEY=                                     # exactly 32-byte hex (64 chars)

# Upstash Redis — use the rediss:// (TLS) URL.
REDIS_URL=rediss://default:PASS@xxx.upstash.io:6379

# monday.com app (Developer Center → your app)
MONDAY_CLIENT_ID=
MONDAY_CLIENT_SECRET=
MONDAY_SIGNING_SECRET=
MONDAY_OAUTH_REDIRECT_URI=https://mvs-api.onrender.com/auth/monday/callback
MONDAY_SCOPES=me:read boards:read users:read account:read

# LiveKit Cloud (optional — spatial audio/video; 503 until set)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Cloudflare R2 (S3-compatible object storage; optional — uploads 503 until set)
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=mvs-assets
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=https://assets.mondayvirtual.eu     # R2 public bucket / custom domain

# Observability (optional — leave unset to disable)
SENTRY_DSN=

# ===========================================================================
# RENDER · service "mvs-realtime"  (Socket.IO presence)  — Render dashboard
# ===========================================================================
# NODE_ENV=production            (same)
# WEB_PUBLIC_URL=...             (same Vercel origin)
# DATABASE_URL=...              (same Neon POOLED url — realtime reads events/presence)
# REDIS_URL=...                 (same Upstash url)
# JWT_SECRET=...                (MUST be byte-identical to mvs-api)
# SENTRY_DSN=                   (optional)
# Render injects $PORT — do NOT set REALTIME_PORT.

# ===========================================================================
# VERCEL · project "web"  (Next.js)   — set as Build & Runtime env in Vercel
# These are NEXT_PUBLIC_* → inlined at BUILD time. A redeploy is needed to change.
# ===========================================================================
NEXT_PUBLIC_API_URL=https://mvs-api.onrender.com
NEXT_PUBLIC_REALTIME_URL=https://mvs-realtime.onrender.com
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
NEXT_PUBLIC_SENTRY_DSN=                              # optional

# ===========================================================================
# GITHUB ACTIONS (deploy.yml migrate job)  — set as repo Secrets
# ===========================================================================
# DATABASE_URL          = Neon POOLED url (same as above)
# DIRECT_DATABASE_URL   = Neon DIRECT (unpooled) url — migrations run here
#   e.g. postgresql://USER:PASS@ep-xxx.eu-central-1.aws.neon.tech/mvs?sslmode=require
